{
  "name": "menda",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "dev:webpack": "next dev --webpack",
    "dev:clean": "rm -rf .next && next dev --webpack",
    "build": "next build --webpack",
    "analyze": "ANALYZE=true pnpm build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "perf:match-flow": "npx tsx scripts/perf/match-flow.ts",
    "scrape-providers": "npx tsx scripts/scrape-providers.ts",
    "sync-provider-reviews": "npx tsx scripts/sync-provider-reviews.ts",
    "check:diagnoses-table": "sh -c 'if grep -rE \"from\\(['\"'\"']conversations['\"'\"']\\)\" src scripts --include=\"*.ts\" --include=\"*.tsx\" -q; then echo \"Use diagnoses table, not conversations\"; exit 1; fi'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:db": "vitest run --config vitest.db.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "scripts:refresh-llm-fixtures": "npx tsx scripts/refresh-llm-fixtures.ts",
    "cost:reconcile": "npx tsx scripts/cost-reconciliation.ts",
    "dev:preview": "NEXT_DIST_DIR=.next-preview next dev"
  },
