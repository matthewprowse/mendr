# =============================================================================
# Mendr — Playwright E2E env template
# Copy to `.env.test` and fill in real values for the variables that you want
# the local Next.js server to read while running `pnpm test:e2e`.
#
# NEVER commit a populated `.env.test` — it is gitignored alongside the other
# environment files. Only `.env.test.example` lives in version control.
#
# The Playwright `webServer` in `playwright.config.ts` injects MOCK_LLM=1,
# MOCK_PLACES=1, and MOCK_BRAVE=1 directly, so those three flags do not need
# to be set here. They are listed below for clarity.
# =============================================================================

# Supabase — required for any spec that touches auth, saved providers, or
# contractor onboarding (specs 03 and 04). If you only run the homeowner
# happy-path specs (01, 02, 06), these can be left blank.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key. Needed for the contractor application back-end
# and for admin approval flows.
SUPABASE_SERVICE_ROLE_KEY=

# LLM / external-search mock flags. These are also injected by
# `playwright.config.ts` but documented here so anyone reading the file knows
# the contract.
MOCK_LLM=1
MOCK_PLACES=1
MOCK_BRAVE=1

# Email — Resend is mocked at the API boundary by RESEND_API_KEY=test-stub.
RESEND_API_KEY=test-stub
RESEND_FROM=Mendr <noreply@example.test>
RESEND_ADMIN_EMAIL=admin@example.test

# Cron + admin auth tokens used by protected routes.
CRON_SECRET=test-cron
ADMIN_PASSWORD=test-admin

# Disable Next.js telemetry on the test runner.
NEXT_TELEMETRY_DISABLED=1
