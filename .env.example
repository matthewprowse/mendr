# Copy to `.env` and fill in. Used for legal/POPIA disclosures on the Terms and Privacy pages (NEXT_PUBLIC_* are exposed to the browser).

NEXT_PUBLIC_APP_URL=https://example.com

# Operator (responsible party). Leave unset to show a not-yet-published notice until configured.
NEXT_PUBLIC_OPERATOR_LEGAL_NAME=
NEXT_PUBLIC_OPERATOR_LEGAL_FORM=Private company registered in South Africa
NEXT_PUBLIC_OPERATOR_PHYSICAL_ADDRESS=
NEXT_PUBLIC_OPERATOR_POSTAL_ADDRESS=

# Legal / Terms contact (ECTA disclosure). Shown on Terms of Service.
NEXT_PUBLIC_LEGAL_EMAIL=

# Privacy contact & Information Officer (POPIA). If officer email is empty, privacy email is used.
NEXT_PUBLIC_PRIVACY_EMAIL=
NEXT_PUBLIC_INFORMATION_OFFICER_NAME=
NEXT_PUBLIC_INFORMATION_OFFICER_EMAIL=

# Reddit dataset scraper (server-side only, not exposed to browser)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
# Same project as Next.js; NEXT_PUBLIC_* is enough if SUPABASE_* are unset
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional aliases (often already in app/.env for the web app):
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_TYPES_TABLE=services
SUPABASE_SERVICE_TYPES_COLUMN=label


# =============================================================================
# Scandio - Environment Variables
# Copy to .env and fill in your values. Never commit .env or .env.local.
# =============================================================================

# Google Gemini API (AI diagnosis)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Google Places API (provider search, Maps)
# Get your key at: https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_PLACES_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=
# Maps JavaScript API (pro page map, match page map). Can be same key as above with Maps JavaScript API enabled.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Voice transcription (/api/transcribe): service account JSON, not an API key. Enable "Cloud Speech-to-Text API" for the GCP project.
# Save the downloaded key next to repo: app/credentials/google-speech-sa.json — see credentials/.gitignore
GOOGLE_APPLICATION_CREDENTIALS=
# Alternative (e.g. Vercel): full JSON on one line; when set it overrides GOOGLE_APPLICATION_CREDENTIALS above.
# GOOGLE_SPEECH_CREDENTIALS_JSON=

# Supabase (auth, database, storage)
# Get your keys at: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

ADMIN_PASSWORD=

SEND_EMAIL_HOOK_SECRET=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_ADMIN_EMAIL=

# Reddit API (dataset extraction script)
# Create app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USERNAME=your_reddit_username_here
REDDIT_PASSWORD=your_reddit_password_here

# OpenAI API (dataset normalization script)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Temporary local testing bypasses
DISABLE_RATE_LIMIT=true
DISABLE_DIAGNOSIS_DAILY_QUOTA=true

GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
GOOGLE_CUSTOM_SEARCH_API_KEY=

BRAVE_SEARCH_API_KEY=
