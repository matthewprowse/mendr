# =============================================================================
# Scandio - Environment Variables
# Copy to .env and fill in your values. Never commit .env or .env.local.
# =============================================================================

# Google Gemini API (AI diagnosis)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Google Places API (provider search, Maps)
# Get your key at: https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_PLACES_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# Supabase (auth, database, storage)
# Get your keys at: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
